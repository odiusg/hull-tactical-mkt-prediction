# -----------------------------------
# Python cache / compiled files
# -----------------------------------
__pycache__/
*.py[cod]
*.pyo
*.so
*.egg-info/
build/
dist/

# Virtual environments
.venv/
env/
venv/
ENV/

# Editors
.vscode/
.idea/
.DS_Store

# Jupyter
.ipynb_checkpoints/

# -----------------------------------
# Project-specific data / outputs
# -----------------------------------

# Raw + interim + processed data (never push)
data/**
!data/raw/.gitkeep
!data/raw/README.md
!data/interim/.gitkeep
!data/interim/README.md
!data/processed/.gitkeep

# Results & artifacts
results/**
!results/.gitkeep
artifacts/**
!artifacts/.gitkeep
configs/*.json

# Misc generated files
*.xlsx
*.csv
*.png
*.pdf
*.json
*.html
*.joblib
*.pkl
*.log

# Claude Code IDE settings (may contain local paths)
.claude/

# v2 MLflow tracking data (not code, regenerable)
v2/mlruns/
v2/mlflow.db

# v2 generated results (regenerable)
v2/results/

# v2 report images (keep for GitHub rendering)
!v2/reports/images/*.png
!v2/reports/images/*.jpg

# Stray files
=*

# Windows / Mac cruft
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# WSL Windows Alternate Data Streams
*:Zone.Identifier
